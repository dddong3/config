# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"

plugins=(
  git
  colorize
  command-not-found
  zoxide
)

source $ZSH/oh-my-zsh.sh

export PATH="$HOME/.local/bin:$PATH"

if type brew &>/dev/null; then
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
  autoload -Uz compinit
  compinit
fi

source "$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# mise (version manager)
eval "$(mise activate zsh)"

# Go (runtime managed by mise, GOPATH for user packages)
export GOPATH=$HOME/go
export PATH=$PATH:$GOPATH/bin

# uv completions
eval "$(uv generate-shell-completion zsh)"
eval "$(uvx --generate-shell-completion zsh)"

# Secrets (pulled from Bitwarden once, stored locally)
# First-time setup: bw-setup-secrets
[ -f ~/.secrets ] && source ~/.secrets

bw-setup-secrets() {
  command -v bw &>/dev/null || { echo "Install first: brew install bitwarden-cli"; return 1; }
  bw config server https://***REMOVED***
  bw login 2>/dev/null || true
  export BW_SESSION=$(bw unlock --raw)
  bw get notes dotfiles-secrets > ~/.secrets
  chmod 600 ~/.secrets
  source ~/.secrets
  echo "Secrets saved to ~/.secrets and loaded."
}

# Colorize plugin
export ZSH_COLORIZE_CHROMA_FORMATTER=terminal256
export ZSH_COLORIZE_TOOL=chroma

# Disable default ctrl+R (use atuin instead)
bindkey -r '^R'

# Atuin (shell history sync)
. "$HOME/.atuin/bin/env"
eval "$(atuin init zsh)"

# Aliases
alias c='ccat'

# Prompt (must be last)
eval "$(starship init zsh)"
