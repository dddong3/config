# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"

plugins=(
  git
  colorize
  command-not-found
  zoxide
)

[ -d "$ZSH" ] && source $ZSH/oh-my-zsh.sh

export PATH="$HOME/.local/bin:$PATH"

if type brew &>/dev/null; then
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
  autoload -Uz compinit
  compinit

  # zsh-syntax-highlighting (must be inside brew guard)
  ZSH_HL="$(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  [ -f "$ZSH_HL" ] && source "$ZSH_HL"
fi

# mise (version manager)
command -v mise &>/dev/null && eval "$(mise activate zsh)"

# Go (runtime managed by mise, GOPATH for user packages)
export GOPATH=$HOME/go
export PATH=$PATH:$GOPATH/bin

# uv completions
if command -v uv &>/dev/null; then
  eval "$(uv generate-shell-completion zsh)"
  eval "$(uvx --generate-shell-completion zsh)"
fi

# Secrets (pulled from Bitwarden once, stored locally)
# First-time setup: bw-setup-secrets
[ -f ~/.secrets ] && source ~/.secrets

bw-setup-secrets() {
  command -v bw &>/dev/null || { echo "Install first: brew install bitwarden-cli"; return 1; }
  bw config server https://***REMOVED***
  bw login || true
  local BW_SESSION
  BW_SESSION=$(bw unlock --raw)
  local tmp
  tmp=$(mktemp)
  BW_SESSION="$BW_SESSION" bw get notes dotfiles-secrets > "$tmp"
  if [ -s "$tmp" ]; then
    mv "$tmp" ~/.secrets
    chmod 600 ~/.secrets
    source ~/.secrets
    echo "Secrets saved to ~/.secrets and loaded."
  else
    rm -f "$tmp"
    echo "Error: failed to fetch secrets (empty response)."
    return 1
  fi
}

# Colorize plugin
export ZSH_COLORIZE_CHROMA_FORMATTER=terminal256
export ZSH_COLORIZE_TOOL=chroma

# Disable default ctrl+R (use atuin instead)
bindkey -r '^R'

# Atuin (shell history sync, installed via brew)
command -v atuin &>/dev/null && eval "$(atuin init zsh)"

# Aliases
alias c='ccat'

# Prompt (must be last)
command -v starship &>/dev/null && eval "$(starship init zsh)"
