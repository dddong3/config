# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"

plugins=(
  git
  colorize
  command-not-found
  zoxide
)

# Colorize plugin (evaluated lazily at call time, must be set before first use)
export ZSH_COLORIZE_CHROMA_FORMATTER=terminal256
export ZSH_COLORIZE_TOOL=chroma

export PATH="$HOME/.local/bin:$PATH"

# Cache brew prefix (avoids repeated subprocess forks)
if type brew &>/dev/null; then
  BREW_PREFIX="$(brew --prefix)"
fi

# Completions: FPATH must be set BEFORE oh-my-zsh.sh (which calls compinit)
if [ -n "$BREW_PREFIX" ]; then
  FPATH="$BREW_PREFIX/share/zsh-completions:$BREW_PREFIX/share/zsh/site-functions:$FPATH"
fi

# Skip compaudit insecure-dir warnings for brew-managed dirs
export ZSH_DISABLE_COMPFIX=true
[ -d "$ZSH" ] && source $ZSH/oh-my-zsh.sh

# mise (version manager)
command -v mise &>/dev/null && eval "$(mise activate zsh)"

# fzf (shell integration — key bindings + completion)
# Ctrl-R: history search, Ctrl-T: file picker, Alt-C: cd into subdir, **<Tab>: completion
if [ -n "$BREW_PREFIX" ]; then
  FZF_SHELL="$BREW_PREFIX/opt/fzf/shell"
  [ -f "$FZF_SHELL/key-bindings.zsh" ] && source "$FZF_SHELL/key-bindings.zsh"
  [ -f "$FZF_SHELL/completion.zsh" ]   && source "$FZF_SHELL/completion.zsh"
fi
if command -v rg &>/dev/null; then
  export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!.git"'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
fi

# zsh-syntax-highlighting (must be sourced last)
if [ -n "$BREW_PREFIX" ]; then
  ZSH_HL="$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  [ -f "$ZSH_HL" ] && source "$ZSH_HL"
fi

# Google Cloud SDK
if [ -n "$BREW_PREFIX" ]; then
  GCLOUD_DIR="$BREW_PREFIX/share/google-cloud-sdk"
  [ -f "$GCLOUD_DIR/path.zsh.inc" ] && source "$GCLOUD_DIR/path.zsh.inc"
  [ -f "$GCLOUD_DIR/completion.zsh.inc" ] && source "$GCLOUD_DIR/completion.zsh.inc"
fi

# Go (runtime managed by mise, GOPATH for user packages)
export GOPATH=$HOME/go
export PATH=$PATH:$GOPATH/bin

# uv completions
if command -v uv &>/dev/null; then
  eval "$(uv generate-shell-completion zsh)"
  eval "$(uvx --generate-shell-completion zsh)"
fi

# Secrets (pulled from Bitwarden once via scripts/bw-setup.sh)
[ -f ~/.secrets ] && source ~/.secrets

# Atuin (shell history sync, installed via brew)
command -v atuin &>/dev/null && eval "$(atuin init zsh)"

# Aliases
alias c='ccat'

# Prompt (must be last)
command -v starship &>/dev/null && eval "$(starship init zsh)"
